## Backend (Node/Express)
PORT=5000
MONGODB_URI=mongodb://localhost:27017/carbon-intelligence
JWT_SECRET=change_me_in_production
NODE_ENV=development

# Default admin bootstrap (runs on server start)
# DISABLE_ADMIN_BOOTSTRAP=true
# BOOTSTRAP_ADMIN_EMAIL=carbonintelligence@sustainow.in
# BOOTSTRAP_ADMIN_PASSWORD=admin123
# BOOTSTRAP_ADMIN_SYNC_PASSWORD=true  # reset designated admin password to BOOTSTRAP_ADMIN_PASSWORD on startup

# The web app origin (used for CORS, links, etc.)
# FRONTEND_URL=http://localhost:3000

# Optional: enable HTTPS for backend server
# Set HTTPS_ENABLED=true and provide absolute or relative cert paths
HTTPS_ENABLED=false
SSL_KEY_PATH=
SSL_CERT_PATH=
SSL_CA_PATH=
SSL_PASSPHRASE=

# Optional: if enabling email features (do not commit real creds)
EMAIL_USER=
EMAIL_PASS=

# Registration OTP verification (disabled by default for testing)
REGISTRATION_OTP_ENABLED=false
REGISTRATION_OTP_TTL_SECONDS=600
REGISTRATION_OTP_LENGTH=6
REGISTRATION_OTP_EMAIL_ENABLED=true
REGISTRATION_OTP_SMS_ENABLED=true
REGISTRATION_OTP_RESEND_COOLDOWN_SECONDS=60
REGISTRATION_OTP_MAX_RESEND_ATTEMPTS=3
REGISTRATION_OTP_MAX_VERIFY_ATTEMPTS=5
REGISTRATION_OTP_LOCK_DURATION_SECONDS=900
REGISTRATION_OTP_REQUEST_WINDOW_MS=600000
REGISTRATION_OTP_REQUEST_MAX_PER_WINDOW=10
REGISTRATION_OTP_VERIFY_WINDOW_MS=600000
REGISTRATION_OTP_VERIFY_MAX_PER_WINDOW=20

# Airtel DLT/MSG91 config for registration OTP SMS
AIRTEL_DLT_SMS_HEADER=
AIRTEL_DLT_OTP_TEMPLATE_ID=
AIRTEL_DLT_OTP_MESSAGE=Your OTP for registration is {{OTP}}. It is valid for 10 minutes. Do not share this OTP.

# MSG91 credentials (required for SMS dispatch when OTP enabled)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=4
MSG91_COUNTRY_CODE=91

FRONTEND_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000
# AI processing timeout (ms) — default 7 minutes; increase for very large PDFs
AI_REQUEST_TIMEOUT=420000
# RC-1 lifecycle: enforce status transitions (true/false)
DOCUMENT_LIFECYCLE_ENFORCE_TRANSITIONS=true
# Prevent overlapping processDocument for same document id (not duplicate bill detection)
DOCUMENT_PROCESSING_SINGLE_FLIGHT=true
# BE-103: heartbeat during long processing (metadata + processingResults; does not change status)
DOCUMENT_PROCESSING_HEARTBEAT_ENABLED=true
DOCUMENT_PROCESSING_HEARTBEAT_INTERVAL_MS=30000
# BE-110: bulk uses same processDocument path; concurrency reserved for future queue (1 = sequential)
DOCUMENT_BULK_PROCESSING_CONCURRENCY=1
# Future BE-104: external queue (false keeps setImmediate path)
DOCUMENT_PROCESSING_QUEUE_ENABLED=false
# Log hint when upload exceeds this size (bytes)
DOCUMENT_LARGE_FILE_WARN_BYTES=2097152
# Skip redundant backend OCR when AI model returns confident extraction (0-1)
AI_SKIP_BACKEND_OCR_MIN_CONFIDENCE=0.45
# Set to 1 to skip expensive multi-engine OCR reconciliation on every upload
SKIP_MULTI_OCR_CHECK=0
# RC-5C: gap-fill empty contract fields from multi-engine OCR texts (0=off, 1=on)
MULTI_OCR_RECOVERY_ENABLED=0
# RC-5E: GSTIN label-aware recovery runs in applyPostMergeRecovery (always on when rawText present)
# RC-5F: invoice/vendor/date label-aware recovery (0=off, 1=on)
ACCURACY_RECOVERY_ENABLED=0
ITEM_RECOVERY_ENABLED=0

# Razorpay (India payments) — MSME checkout only; informational mode does not block features
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional: AI invoice engine (see ai-model/deploy/)
# ENABLE_COMPLIANCE_AUDIT=1
# ENABLE_ACTIVE_LEARNING=1
# ENABLE_EDGE_OCR=1
# MLOPS_AUTO_ROLLBACK=1
# MLOPS_AUTO_RETRAIN=0
# INVOICE_COMPLIANCE_REGION=IN
# AUDIT_RETENTION_POLICY_DAYS=2555
# FX_BASE_CURRENCY=INR
# LIVE_FX_ENABLED=1
# REDIS_URL=redis://localhost:6379/0
# MLOPS_ZERO_TOUCH=1
# MLOPS_KPI_MIN_MEAN_F1=0.78
# ADMIN_API_KEY=change_me_for_admin_endpoints
# LIVE_FX_PROVIDER=frankfurter
# OPENEXCHANGERATES_APP_ID=
# EXCHANGERATE_API_KEY=
# TAX_VENDOR_API_URL=
# TAX_VENDOR_API_KEY=
# ENFORCE_CERTIFICATION_GATE=0
# DEPLOY_REGION=ap-south-1
# INVOICE_REGION=IN
# SQS_QUEUE_URL=
# Optional: semantic API version exposed by /health and /api/version.
# If omitted, backend/package.json version is used.
API_VERSION=

# Optional: baseline monorepo version exposed by /health and /api/version.
# If omitted, root package.json version is used.
BASELINE_CODEBASE_VERSION=

# Optional: Indian Carbon Market portal (deep links; no API key required)
INDIAN_CARBON_PORTAL_BASE_URL=https://indiancarbonmarket.gov.in

# Optional: Indian Carbon Market registry API integration
INDIAN_CARBON_REGISTRY_ENABLED=false
INDIAN_CARBON_REGISTRY_BASE_URL=https://api.indiancarbonmarket.gov.in
INDIAN_CARBON_REGISTRY_API_KEY=
INDIAN_CARBON_REGISTRY_TIMEOUT_MS=15000
INDIAN_CARBON_REGISTRY_HEALTH_PATH=/v1/health
INDIAN_CARBON_REGISTRY_MSME_CREDITS_PATH=/v1/msmes/:msmeId/credits
INDIAN_CARBON_REGISTRY_SYNC_PATH=/v1/msmes/:msmeId/credits/sync
INDIAN_CARBON_REGISTRY_RETIREMENT_PATH=/v1/msmes/:msmeId/retirements

# Encrypts per-MSME connector credentials at rest (falls back to JWT_SECRET if unset)
CONNECTOR_CREDENTIALS_KEY=

# Optional: Zoho Books API sync (India data center defaults)
ZOHO_BOOKS_ENABLED=false
ZOHO_BOOKS_CLIENT_ID=
ZOHO_BOOKS_CLIENT_SECRET=
ZOHO_BOOKS_REFRESH_TOKEN=
ZOHO_BOOKS_ORGANIZATION_ID=
ZOHO_BOOKS_API_DOMAIN=https://www.zohoapis.in
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.in
ZOHO_BOOKS_TIMEOUT_MS=15000

# Optional: QuickBooks Online API sync
QUICKBOOKS_ENABLED=false
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENVIRONMENT=production
QUICKBOOKS_TIMEOUT_MS=15000

# Optional: TallyPrime HTTP API sync (local Tally as server, default port 9000)
# Enable in TallyPrime: Exchange → Data Synchronization → act as Server, port 9000; load a company.
# @see https://help.tallysolutions.com/integrate-with-tallyprime/
TALLY_ENABLED=false
TALLY_HOST=localhost
TALLY_PORT=9000
# Optional fallback; live sync uses the authenticated MSME company name (legalName) when unset
TALLY_COMPANY_NAME=
TALLY_API_FORMAT=json
TALLY_REPORT_ID=DayBook
TALLY_FROM_DATE=
TALLY_TO_DATE=
TALLY_TIMEOUT_MS=30000

# Partner / third-party public API (see docs/root/PARTNER_API_DOCUMENTATION.md)
PARTNER_API_SUPPORT_EMAIL=support@sustainow.in
PARTNER_COMMERCIAL_EMAIL=contact@sustainow.in
# Partner usage quota enforcement: off | soft (warn headers) | hard (429 when exceeded)
PARTNER_USAGE_ENFORCEMENT=soft
# Partner contract billing enforcement: off | soft (warn headers) | hard (402 when inactive)
PARTNER_BILLING_ENFORCEMENT=soft